# Copy to .env for local development

# Database (Railway provides DATABASE_URL automatically when you add a Postgres service)
DATABASE_URL=postgresql://postgres:govrag@localhost:5432/govrag

# LLM Provider: "ollama" (local) | "groq" (cloud, free) | "openai"
LLM_PROVIDER=ollama

# Ollama (local dev)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# Groq (cloud deployment — get a free key at console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI-compatible (optional)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
